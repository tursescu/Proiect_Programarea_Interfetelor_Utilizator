<Window x:Class="InterfataGraficaWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestiune Patiserie" Height="450" Width="800"
        Background="#F5F6FA">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Lista Produse" FontSize="24" FontWeight="Bold" Foreground="#2F3640"/>
            <Button x:Name="btnIncarca" Content="Reîncarcă Produse" Width="120" Margin="20,5,0,5" Click="btnIncarca_Click"/>
        </StackPanel>

        <DataGrid x:Name="tabelProduse" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="#DCDDE1" RowBackground="White">
        </DataGrid>

    </Grid>
</Window>
