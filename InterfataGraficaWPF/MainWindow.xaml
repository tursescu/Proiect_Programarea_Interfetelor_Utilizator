<Window x:Class="InterfataGraficaWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cofetărie - Gestiune produse și comenzi"
        Height="700" Width="1000"
        MinWidth="850" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <DockPanel>

        <StackPanel DockPanel.Dock="Left"
                    Width="200"
                    Background="#EEEEEE">
            <TextBlock Text="Meniu" FontSize="18" FontWeight="Bold" Margin="10"/>
            <Button x:Name="btnMeniuAdaugaProdus" Content="Adaugă produs"
                    Height="40" Margin="10,5" Click="btnMeniuAdaugaProdus_Click"/>
            <Button x:Name="btnMeniuListaProduse" Content="Listă / Caută produse"
                    Height="40" Margin="10,5" Click="btnMeniuListaProduse_Click"/>
            <Button x:Name="btnMeniuAdaugaComanda" Content="Adaugă comandă"
                    Height="40" Margin="10,5" Click="btnMeniuAdaugaComanda_Click"/>
            <Button x:Name="btnMeniuListaComenzi" Content="Listă / Modifică comenzi"
                    Height="40" Margin="10,5" Click="btnMeniuListaComenzi_Click"/>
        </StackPanel>

        <Grid>

            <ScrollViewer x:Name="panelAdaugaProdus" Visibility="Visible" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock Text="Adaugă produs nou" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="_Nume produs" Target="{Binding ElementName=txtNumeProdus}"
                                   FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtNumeProdus" Height="28" Padding="6,0"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock x:Name="tbErrNumeProdus" FontSize="11" Foreground="Red"
                                       Margin="0,2,0,0" Visibility="Collapsed"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="_Pret (lei)" Target="{Binding ElementName=txtPretProdus}"
                                   FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtPretProdus" Height="28" Padding="6,0"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock x:Name="tbErrPretProdus" FontSize="11" Foreground="Red"
                                       Margin="0,2,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="_Detalii" Target="{Binding ElementName=txtDetaliiProdus}"
                           FontWeight="Bold" Padding="0" Margin="0,8,0,4"/>
                    <TextBox x:Name="txtDetaliiProdus" Height="28" Padding="6,0"
                             VerticalContentAlignment="Center"/>
                    <TextBlock x:Name="tbErrDetaliiProdus" FontSize="11" Foreground="Red"
                               Margin="0,2,0,8" Visibility="Collapsed"/>

                    <GroupBox Header="Caracteristici produs" Margin="0,8,0,10">
                        <WrapPanel Orientation="Horizontal" Margin="5">
                            <CheckBox x:Name="ckbDePost" Content="De post" Margin="5,5,20,5"/>
                            <CheckBox x:Name="ckbFaraZahar" Content="Fără zahăr" Margin="5,5,20,5"/>
                            <CheckBox x:Name="ckbFaraGluten" Content="Fără gluten" Margin="5,5,20,5"/>
                            <CheckBox x:Name="ckbFaraLactoza" Content="Fără lactoză" Margin="5"/>
                        </WrapPanel>
                    </GroupBox>

                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Button x:Name="btnSalveazaProdus" Content="_Adaugă"
                                Width="120" Height="32" FontWeight="Bold"
                                Margin="0,0,10,0" Click="btnSalveazaProdus_Click"/>
                        <Button x:Name="btnReseteazaProdus" Content="_Reset"
                                Width="120" Height="32" FontWeight="Bold"
                                Click="btnReseteazaProdus_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="panelListaProduse" Visibility="Collapsed" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Listă / Caută produse"
                           FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="Caută după nume:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="txtCautaProdus" Height="28"
                             Padding="6,0" VerticalContentAlignment="Center" Margin="5,0"/>
                    <Button Grid.Column="2" x:Name="btnCautaProdus" Content="Caută"
                            Width="100" Height="28" Margin="5,0,0,0"
                            Click="btnCautaProdus_Click"/>
                    <Button Grid.Column="3" x:Name="btnAfiseazaToateProduse" Content="Toate"
                            Width="100" Height="28" Margin="5,0,0,0"
                            Click="btnAfiseazaToateProduse_Click"/>
                    <Label Grid.Column="4" x:Name="lblMesajCautareProdus"
                           Foreground="Red" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>

                <DataGrid Grid.Row="2" x:Name="dgProduse"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="All"
                          AlternatingRowBackground="#F5F5F5" RowHeight="26">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="180"/>
                        <DataGridTextColumn Header="Preț" Binding="{Binding PretUnitar}" Width="80"/>
                        <DataGridTextColumn Header="Detalii" Binding="{Binding Detalii}" Width="*"/>
                        <DataGridTextColumn Header="Caracteristici" Binding="{Binding Caracteristici}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <ScrollViewer x:Name="panelAdaugaComanda" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock Text="Adaugă comandă nouă" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="_Nume client" Target="{Binding ElementName=txtNumeClient}"
                                   FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtNumeClient" Height="28" Padding="6,0"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock x:Name="tbErrNumeClient" FontSize="11" Foreground="Red"
                                       Margin="0,2,0,0" Visibility="Collapsed"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="_Prenume client" Target="{Binding ElementName=txtPrenumeClient}"
                                   FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtPrenumeClient" Height="28" Padding="6,0"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock x:Name="tbErrPrenumeClient" FontSize="11" Foreground="Red"
                                       Margin="0,2,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="_Telefon" Target="{Binding ElementName=txtTelefon}"
                                   FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTelefon" Height="28" Padding="6,0"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock x:Name="tbErrTelefon" FontSize="11" Foreground="Red"
                                       Margin="0,2,0,0" Visibility="Collapsed"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Label Content="_Data livrare" Target="{Binding ElementName=dpDataLivrare}"
                                   FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpDataLivrare" Height="28"/>
                        </StackPanel>
                    </Grid>

                    <GroupBox Header="Adaugă produse la comandă" Margin="0,10,0,10">
                        <StackPanel Margin="5">
                            <Grid Margin="0,5,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" x:Name="cbProduse" Height="28"
                                          DisplayMemberPath="Nume"
                                          VerticalContentAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="txtCantitate" Height="28"
                                         Padding="6,0" Margin="5,0"
                                         VerticalContentAlignment="Center"
                                         Text="1"/>
                                <Button Grid.Column="2" x:Name="btnAdaugaProdusInComanda"
                                        Content="+ Adaugă" Width="100" Height="28"
                                        Click="btnAdaugaProdusInComanda_Click"/>
                            </Grid>
                            <TextBlock x:Name="tbErrCantitate" FontSize="11" Foreground="Red"
                                       Margin="0,2,0,5" Visibility="Collapsed"/>

                            <DataGrid x:Name="dgArticoleComanda" Height="120"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="All"
                                      AlternatingRowBackground="#F5F5F5" RowHeight="24">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Produs" Binding="{Binding ProdusComandat.Nume}" Width="*"/>
                                    <DataGridTextColumn Header="Cantitate" Binding="{Binding Cantitate}" Width="80"/>
                                    <DataGridTextColumn Header="Preț unitar" Binding="{Binding ProdusComandat.PretUnitar}" Width="100"/>
                                    <DataGridTextColumn Header="Total" Binding="{Binding PretTotalArticol}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock x:Name="tbTotalComanda" Text="Total comandă: 0 lei"
                                       FontWeight="Bold" FontSize="14"
                                       Margin="0,8,0,0" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </GroupBox>

                    <TextBlock x:Name="tbErrProduse" FontSize="11" Foreground="Red"
                               Margin="0,2,0,8" Visibility="Collapsed"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Button x:Name="btnSalveazaComanda" Content="_Salvează comanda"
                                Width="160" Height="32" FontWeight="Bold"
                                Margin="0,0,10,0" Click="btnSalveazaComanda_Click"/>
                        <Button x:Name="btnReseteazaComanda" Content="_Reset"
                                Width="120" Height="32" FontWeight="Bold"
                                Click="btnReseteazaComanda_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="panelListaComenzi" Visibility="Collapsed" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Listă comenzi"
                           FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" x:Name="dgComenzi"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="All"
                          AlternatingRowBackground="#F5F5F5" RowHeight="26"
                          SelectionMode="Single"
                          SelectionChanged="dgComenzi_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding NumeClient}" Width="120"/>
                        <DataGridTextColumn Header="Prenume" Binding="{Binding PrenumeClient}" Width="120"/>
                        <DataGridTextColumn Header="Telefon" Binding="{Binding NumarTelefon}" Width="120"/>
                        <DataGridTextColumn Header="Data" Binding="{Binding DataLivrarii, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="Status comandă" Binding="{Binding StatusComanda}" Width="120"/>
                        <DataGridTextColumn Header="Status plată" Binding="{Binding StatusPlata}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <GroupBox Grid.Row="2" Header="Modifică status comandă selectată" Margin="0,10,0,0">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Label Content="Status comandă" FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rbInAsteptare" Content="În așteptare"
                                             GroupName="StatusComanda" Margin="0,0,15,0"/>
                                <RadioButton x:Name="rbInProcesare" Content="În procesare"
                                             GroupName="StatusComanda" Margin="0,0,15,0"/>
                                <RadioButton x:Name="rbFinalizata" Content="Finalizată"
                                             GroupName="StatusComanda"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Label Content="Status plată" FontWeight="Bold" Padding="0" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rbNeplatita" Content="Neplătită"
                                             GroupName="StatusPlata" Margin="0,0,15,0"/>
                                <RadioButton x:Name="rbPlatita" Content="Plătită"
                                             GroupName="StatusPlata"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" x:Name="btnSalveazaStatus"
                                Content="Salvează modificările"
                                Width="160" Height="32" FontWeight="Bold"
                                VerticalAlignment="Bottom"
                                Click="btnSalveazaStatus_Click"/>
                    </Grid>
                </GroupBox>
            </Grid>

        </Grid>
    </DockPanel>
</Window>